{
  "environment": [],
  "setup": {
    "macos": [
      "MAIN="/Users/rcantu/Code/gradient-server"
WT_NAME=$(basename "$PWD")

mkdir -p data
if [ -d "$MAIN/data" ]; then
  rsync -a --delete "$MAIN/data/" data/
fi

SRC_VOL=gradient-server_pg_data
DST_VOL=${WT_NAME}_pg_data
docker volume create "${DST_VOL}" >/dev/null
docker run --rm -v "${SRC_VOL}:/from:ro" -v "${DST_VOL}:/to" alpine ash -c 'cd /from && cp -a . /to || true'

HOST_PG_PORT=$(python3 -c "import socket; s = socket.socket(); s.bind(('', 0)); print(s.getsockname()[1]); s.close()")
if [ -f "$MAIN/.env" ]; then cp "$MAIN/.env" .env; else touch .env; fi

sed -i '' "s|localhost:5432|localhost:${HOST_PG_PORT}|" .env

{
  echo "COMPOSE_PROJECT_NAME=${WT_NAME}"
  echo "HOST_POSTGRES_PORT=${HOST_PG_PORT}"
} >> .env

docker compose up -d
uv sync"
    ]
  },
  "cleanup": {
    "macos": [
      "docker compose down -v"
    ]
  }
}