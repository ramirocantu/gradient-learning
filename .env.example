# Copy to .env and fill in real values. Never commit .env.

# Postgres (matches docker-compose.yml defaults)
POSTGRES_USER=gradient
POSTGRES_PASSWORD=gradient_secret
POSTGRES_DB=gradient
DATABASE_URL=postgresql+asyncpg://gradient:gradient_secret@localhost:5432/gradient

# OpenAI (P0 pivot — single LLM provider, behind services/llm/).
OPENAI_API_KEY=sk-...
# Optional. Set when running against an OpenAI-compatible local server
# (e.g. vLLM/lm-studio). Leave blank for openai.com.
# OPENAI_BASE_URL=

# Model selection — T5 spike outcomes (committed 2026-05-26):
#
#   OPENAI_MODEL = gpt-4.1-mini — categorizer + anki topic resolver default.
#     Picked over gpt-4o-mini for: lower input cost ($0.40 vs $0.15 — comparable
#     output cost, but the tagger is input-bound), better structured-output
#     adherence on long enum lists, and same 128k context.
#
#   OPENAI_CALIBRATOR_MODEL = gpt-4.1-mini — MUST be a non-reasoning chat model
#     (o-series doesn't expose `logprobs`). Same model as tagger so a single
#     warm cache services both passes.
#
#   FEATURE_EXTRACTOR_MODEL = gpt-4.1 — pinned to full GPT-4.1 because feature
#     extraction is the judgment-heavy call (distractor difficulty, jargon
#     density, trap presence). Re-eval via T10 harness can rotate this back
#     to -mini if quality holds.
#
#   EMBEDDING_MODEL = text-embedding-3-small (1536 dim) — §O default.
#
# Override any of the below if a re-eval rotates the choice; no code change.
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_CALIBRATOR_MODEL=gpt-4.1-mini
# CATEGORIZER_MODEL=gpt-4.1-mini
# FEATURE_EXTRACTOR_MODEL=gpt-4.1
# ANKI_TOPIC_RESOLVER_MODEL=gpt-4.1-mini
# EMBEDDING_MODEL=text-embedding-3-small

# Backend auth token shared with the Chrome extension
COACH_TOKEN=change_me_before_use

# Backend base URL — used both for MCP transport and for absolute deep-links
# (e.g. Things 3 export). Single origin since 9.5 R.4 (dashboard + JSON API).
BACKEND_BASE_URL=http://localhost:8000

# Scheduler (Ticket 6.9b) — omit to use defaults
# SCHEDULER_ENABLED=true
# CATEGORIZER_INTERVAL_MINUTES=15
# CATEGORIZER_PER_RUN_BUDGET_USD=0.50
# FEATURE_EXTRACTION_INTERVAL_MINUTES=60

# Anki integration (Phase 11). AnkiConnect addon must be installed in
# Anki desktop and Anki desktop must be running for sync to succeed.
# ANKI_DECK_NAME must match the deck exactly as it appears in Anki;
# common values: "AnKing MCAT Deck", "MileDown". When the sync finds 0
# cards it logs the deck list AnkiConnect knows about so you can spot
# typos — see /admin or /anki pages for the latest sync run.
# Use 127.0.0.1 (NOT localhost) — AnkiConnect binds IPv4 only and `localhost`
# can resolve to ::1, producing spurious `error="anki_not_running"` results.
ANKICONNECT_URL=http://127.0.0.1:8765
ANKI_DECK_NAME="AnKing MCAT Deck"
# ANKI_SYNC_INTERVAL_MINUTES=15

# Anki topic resolver (Phase 11 / T32). LLM pass under parsed `aamc_cc` rows
# → topic_id suggestion. Reuses categorizer model + cache pattern.
# ANKI_TOPIC_RESOLVER_MODEL=claude-haiku-4-5-20251001
# ANKI_TOPIC_RESOLVER_INTERVAL_MINUTES=60
# ANKI_TOPIC_RESOLVER_PER_RUN_BUDGET_USD=0.50
# ANKI_TOPIC_RESOLVER_CONFIDENCE_THRESHOLD=0.5
