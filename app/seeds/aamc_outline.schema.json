{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aamc_outline.schema.json",
  "title": "AAMC MCAT Content Outline",
  "type": "object",
  "required": ["version", "source_urls", "retrieved_at", "sections"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "description": "Year/version of the AAMC outline"
    },
    "source_urls": {
      "type": "array",
      "items": { "type": "string", "format": "uri" },
      "minItems": 1
    },
    "retrieved_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "sections": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": { "$ref": "#/$defs/section" }
    }
  },
  "$defs": {
    "section": {
      "type": "object",
      "required": ["code", "name"],
      "additionalProperties": true,
      "properties": {
        "code": {
          "type": "string",
          "enum": ["CP", "CARS", "BB", "PS"]
        },
        "name": { "type": "string" },
        "_notes": { "type": "string" },
        "foundational_concepts": {
          "type": "array",
          "items": { "$ref": "#/$defs/foundational_concept" }
        },
        "skill_categories": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "description"],
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "passage_disciplines": {
          "type": "object",
          "properties": {
            "humanities": { "type": "array", "items": { "type": "string" } },
            "social_sciences": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "foundational_concept": {
      "type": "object",
      "required": ["code", "name", "content_categories"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^FC\\d{1,2}$"
        },
        "name": { "type": "string" },
        "content_categories": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/content_category" }
        }
      }
    },
    "content_category": {
      "type": "object",
      "required": ["code", "name", "topics"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^\\d{1,2}[A-Z]$"
        },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "topics": {
          "type": "array",
          "items": { "$ref": "#/$defs/topic_node" }
        }
      }
    },
    "topic_node": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "disciplines": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["BIO", "BC", "GC", "OC", "PHY", "PSY", "SOC"]
          }
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/topic_node" }
        }
      }
    }
  }
}
